{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "react": ["./node_modules/@types/react"],
      "react/*": ["./node_modules/@types/react/*", "./node_modules/react/*"],
      "react-native": ["./node_modules/react-native"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "../shared/**/*.ts",
    "../shared/**/*.tsx"
  ]
}
